{
  "expo": {
    "name": "HyperSolid",
    "slug": "hypersolid",
    "scheme": "hypersolid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumosforge.hypersolid",
      "entitlements": {
        "com.apple.developer.default-data-protection": "NSFileProtectionCompleteUntilFirstUnlock"
      }
    },
    "android": {
      "package": "com.lumosforge.hypersolid",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1217"
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "使用 Face ID 解锁你的 HyperSolid 钱包并对交易签名。"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "使用 Face ID 解锁你的 HyperSolid 钱包并对交易签名。"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "@sentry/react-native"
    ]
  }
}
